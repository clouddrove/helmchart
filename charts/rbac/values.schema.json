{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "rbac values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          },
          "namespace": {
            "type": "string",
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          },
          "role": {
            "type": "string",
            "enum": ["view", "edit", "admin"]
          },
          "createNamespace": { "type": "boolean" },
          "subjectKind": {
            "type": "string",
            "enum": ["ServiceAccount", "Group", "User"]
          },
          "subject": { "type": "string", "minLength": 1 }
        },
        "if": {
          "properties": {
            "subjectKind": { "enum": ["Group", "User"] }
          },
          "required": ["subjectKind"]
        },
        "then": { "required": ["subject"] }
      }
    }
  }
}
